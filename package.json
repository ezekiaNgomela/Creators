{
  "name": "creators",
  "version": "0.1.0",
  "packageManager": "npm@10.9.8",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./run-project.ps1",
    "dev": "npm run start",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-local.ps1",
    "backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./run-backend.ps1",
    "frontend": "npm --prefix apps/web run web",
    "typecheck": "npm --prefix apps/web run typecheck"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "debug": "^4.4.3",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
